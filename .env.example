# Phase 1 — Shadow AI Guardrail Gateway
# Copy to .env and fill in values. Never commit .env.

OPENAI_API_KEY=sk-your-openai-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
DEFAULT_PROVIDER=openai
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8000
LOG_LEVEL=INFO

# Required for /v1 routes (Bearer or X-API-Key). Generate a long random string.
GATEWAY_API_KEY=replace-me-with-a-long-random-gateway-key
# Optional comma-separated additional keys:
# GATEWAY_API_KEYS=key2,key3

# Sliding-window limit per authenticated key (default 60).
# To disable limiting, set GATEWAY_RATE_LIMIT_DISABLED=true (not limit=0).
GATEWAY_RATE_LIMIT_PER_MINUTE=60
# GATEWAY_RATE_LIMIT_DISABLED=false
# GATEWAY_MAX_BODY_BYTES=2097152
# GATEWAY_ENABLE_DOCS=false
