# Shared with GitHub Actions (ingest auth) — REQUIRED in production
GOVERNANCE_DASHBOARD_SECRET=change-me-to-a-long-random-string

# Browser site gate (recommended on public Vercel Hobby / production URLs).
# When set, visitors must sign in at /login. Session cookie lasts 7 days.
# Separate from GOVERNANCE_DASHBOARD_SECRET (CI ingest / reviewer unlock).
# GOVERNANCE_SITE_PASSWORD=change-me-site-password

# Optional separate secret for human Approve/Quiz/Merge actions
# (defaults to GOVERNANCE_DASHBOARD_SECRET if unset)
# GOVERNANCE_REVIEWER_SECRET=

# Local-only escape hatch (ignored when NODE_ENV=production)
# GOVERNANCE_ALLOW_INSECURE_DEV=true

# Required on Vercel (auto-injected when you add Upstash Redis from Marketplace)
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
# (Vercel KV aliases also work: KV_REST_API_URL / KV_REST_API_TOKEN)

# Required for Governance Quiz commit status (+ optional Approve & Merge)
# Fine-grained PAT: Commit statuses (read/write); add Contents + PRs for merge
GITHUB_TOKEN=
# or:
# GH_MERGE_TOKEN=
# GH_STATUS_TOKEN=

# Optional: public dashboard URL used in the GitHub check link
# GOVERNANCE_DASHBOARD_PUBLIC_URL=https://shadow-ai-gateway.vercel.app

# Optional: restrict merge/status targets to this owner/name
# GITHUB_REPOSITORY=Alteoziel/Shadow-AI-Gateway
