# Shared with GitHub Actions for POST /api/reviews ingest.
# REQUIRED in production and whenever GOVERNANCE_DASHBOARD_URL is set.
GOVERNANCE_DASHBOARD_SECRET=change-me-to-a-long-random-string

# Optional separate secret for human quiz / approve / reject / merge actions.
# Defaults to GOVERNANCE_DASHBOARD_SECRET if unset.
# GOVERNANCE_REVIEWER_SECRET=

# Local-only escape hatch for demos without secrets.
# Ignored when NODE_ENV=production; never enable on a hosted dashboard.
# GOVERNANCE_ALLOW_INSECURE_DEV=true

# Required only for the "Approve & Merge" button.
# Use a fine-grained PAT or GitHub App token with contents:write
# and pull-requests:write for this repository.
GITHUB_TOKEN=
# or:
# GH_MERGE_TOKEN=
